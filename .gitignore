.planning/
.DS_Store

# Build outputs
/barbacana
/upstream
/sbom/
/image.refs

# Dev tools installed by `make tools` into a local GOBIN.
/bin/

# Top-level rules/ is a dev convenience mirror no longer populated by
# the tool — only CRS_SHA256 and .gitkeep are tracked here.
/rules/*
!/rules/CRS_SHA256
!/rules/.gitkeep

# CRS release tarball cache used by cmd/tools/rules for offline rebuilds.
/.cache/

# CRS rule files are extracted from the pinned upstream tarball by
# `make rules`. The pin (versions.mk + rules/CRS_SHA256) is the source
# of truth; extracted files are derivatives and not tracked.
/internal/protections/crs/rules/
/internal/protections/crs/crs-setup.conf

# Test artifacts
*.test
*.out
coverage.out
tests/e2e/reports/
tests/ftw/crs-tests/
tests/ftw/reports/
tests/gotestwaf/reports/

# Editor / OS
*.swp
*~
.idea/
.vscode/

.claude/